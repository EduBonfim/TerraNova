{
  "expo": {
    "name": "Terra Nova",
    "slug": "terra-nova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/mascote.png",
    "scheme": "terranova",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/mascote.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F8F3"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#527e38",
        "foregroundImage": "./src/assets/mascote.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.eduubonfiim.terranova"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/mascote.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3e92264-a5b2-4bc5-900e-e51b37410a88"
      }
    }
  }
}
